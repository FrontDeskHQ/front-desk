{
  "name": "cli",
  "version": "0.0.0",
  "packageManager": "bun@1.3.5",
  "type": "module",
  "author": "front-desk",
  "files": [
    "src"
  ],
  "bin": {
    "fd": "./src/index.ts"
  },
  "scripts": {
    "lint": "biome lint src",
    "lint:fix": "biome lint --fix src",
    "dev": "bun run src/index.ts",
    "fd": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "bun biome format ./src --fix"
  },
  "devDependencies": {
    "@types/node": "^22.15.2"
  },
  "engines": {
    "bun": ">=1.3.5"
  },
  "dependencies": {
    "@live-state/sync": "catalog:",
    "api": "workspace:*",
    "cac": "^6.7.14",
    "dotenv": "^16.5.0",
    "zod": "catalog:"
  }
}
