{
  "name": "cli",
  "version": "0.0.0",
  "packageManager": "bun@1.3.5",
  "type": "module",
  "author": "front-desk",
  "files": [
    "dist"
  ],
  "bin": {
    "fd": "./dist/index.js"
  },
  "scripts": {
    "lint": "biome lint src",
    "lint:fix": "biome lint --fix src",
    "build": "tsdown",
    "dev": "tsx src/index.ts",
    "fd": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "format": "bun biome format ./src --fix"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "tsdown": "^0.10.2",
    "tsx": "^4.19.3"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "dependencies": {
    "@live-state/sync": "catalog:",
    "api": "workspace:*",
    "cac": "^6.7.14",
    "dotenv": "^16.5.0",
    "zod": "catalog:"
  }
}
